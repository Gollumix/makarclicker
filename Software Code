Color GetDynamicAccent() {
    float time = (float)GetTickCount64() / 1000.0f;
    int r = (int)(127 + 127 * sin(time));
    int g = (int)(127 + 127 * sin(time + 2.0f));
    int b = 255;
    return Color(255, r, g, b);
}

