                g.FillRectangle(&hoverBrush, g_menuRect.X + 5.0f, itemY, g_menuRect.Width - 10.0f, 24.0f);
            }

            
            std::wstring renderText = isSelected ? L"[\u2713] " + options[i] : options[i];
            SolidBrush* textBrush = isSelected ? new SolidBrush(dynamicAccent) : &white;

            g.DrawString(renderText.c_str(), -1, &fS, PointF(g_menuRect.X + 15.0f, itemY + 3.0f), textBrush);

            if (isSelected) delete textBrush;
        }
    }

    float finalBottom = g_showDebug ? 720.0f : 515.0f;
    if (!g_showDebug) g.DrawString(L"", -1, &fS, PointF(midX, finalBottom - 20.0f), &sfC, &dGray);
    std::wstring copyTxt = L"COPYRIGHT 2026 " + g_licenseUser;
    g.DrawString(copyTxt.c_str(), -1, &fS, PointF(midX, finalBottom), &sfC, &gray);

    BitBlt(hdc, 0, 0, rc.right, rc.bottom, memDC, 0, 0, SRCCOPY);
    DeleteObject(memBm); DeleteDC(memDC); EndPaint(hwnd, &ps);
}

LRESULT CALLBACK WindowProc(HWND hwnd, UINT uMsg, WPARAM wParam, LPARAM lParam) {
    switch (uMsg) {
    case WM_CREATE:
        LoadSettings(); FetchHardwareInfo(); g_mainHwnd = hwnd;
        SetLayeredWindowAttributes(hwnd, 0, g_windowAlpha, LWA_ALPHA);
        {
            DWORD cornerPreference = 2;
            DwmSetWindowAttribute(hwnd, 33, &cornerPreference, sizeof(cornerPreference));
        }
        for (int i = 0; i < 80; i++) g_particles.push_back({ (float)(rand() % WIN_WIDTH), (float)(rand() % WIN_HEIGHT_LARGE), (float)((rand() % 10 - 5) / 6.0f), (float)((rand() % 10 - 5) / 6.0f) });
        RegisterHotKey(hwnd, 1, 0, g_bindPVP);
        RegisterHotKey(hwnd, 2, 0, g_bindBridge);
        RegisterHotKey(hwnd, 3, MOD_CONTROL, VK_F10);
        std::thread(ClickerEngine).detach();
        std::thread(UpdateSystemUsage).detach();
        std::thread(CheckForUpdates, hwnd).detach();
        SetTimer(hwnd, 1, 16, 0); return 0;

    case WM_SHOW_UPDATE: {
        HWND hU = CreateWindowExW(WS_EX_TOPMOST | WS_EX_LAYERED, L"MakarUpdate", L"Update", WS_POPUP | WS_VISIBLE, 575, 375, 400, 260, hwnd, 0, GetModuleHandle(0), 0);
        {
            DWORD cornerPreference = 2;
            DwmSetWindowAttribute(hU, 33, &cornerPreference, sizeof(cornerPreference));
        }
        SetLayeredWindowAttributes(hU, 0, 250, LWA_ALPHA); return 0;
    }
    case WM_LBUTTONDOWN: {
        int x = LOWORD(lParam), y = HIWORD(lParam);


        if (g_showSettingsMenu && x >= g_menuRect.X && x <= g_menuRect.X + g_menuRect.Width) {
            for (int i = 0; i < 5; i++) {
                float itemY = g_menuRect.Y + 10.0f + (i * 28.0f);
                if (y >= itemY && y < itemY + 25.0f) {
                    switch (i) {
                    case 0: g_windowAlpha = 255; break; // 100%
                    case 1: g_windowAlpha = 230; break; // 90%
                    case 2: g_windowAlpha = 191; break; // 75%
                    case 3: g_windowAlpha = 153; break; // 60%
                    case 4: g_windowAlpha = 128; break; // 50%
                    }
                    SetLayeredWindowAttributes(hwnd, 0, g_windowAlpha, LWA_ALPHA);
                    SaveSettings();
                    g_showSettingsMenu = false;
                    return 0;
                }
            }
        }

        if (y <= TOP_BAR_HEIGHT) {

            if (x >= 10 && x <= 40) {
                g_showSettingsMenu = !g_showSettingsMenu;
                return 0;
            }
            if (x >= (int)WIN_WIDTH - 40) PostQuitMessage(0);
            else if (x >= (int)WIN_WIDTH - 70) ShowWindow(hwnd, SW_MINIMIZE);
            else { ReleaseCapture(); SendMessage(hwnd, WM_NCLBUTTONDOWN, HTCAPTION, 0); }
        }
        else if (y > 160 && y < 210) { g_isDraggingSlider = true; SetCapture(hwnd); g_showSettingsMenu = false; }
        else if (y > 250 && y < 300 && x > WIN_WIDTH / 2) { g_isBindingPVP = true; g_showSettingsMenu = false; }
        else if (y > 300 && y < 350 && x > WIN_WIDTH / 2) { g_isBindingBridge = true; g_showSettingsMenu = false; }
        else {

            g_showSettingsMenu = false;
        }

        if (g_showDebug && x > WIN_WIDTH / 2 - 75 && x < WIN_WIDTH / 2 + 75 && y > 680 && y < 710) {
            PostQuitMessage(0);
        }
        return 0;
    }
    case WM_LBUTTONUP: g_isDraggingSlider = false; ReleaseCapture(); SaveSettings(); return 0;
    case WM_MOUSEMOVE:
        g_mousePos = { LOWORD(lParam), HIWORD(lParam) };
        if (g_isDraggingSlider) {
            float start = WIN_WIDTH / 2.0f - 150.0f;
            g_cps = std::clamp(1.0f + (((float)LOWORD(lParam) - start) / 300.0f) * 29.0f, 1.0f, 30.0f);
        } return 0;
    case WM_KEYDOWN:
        if (g_isBindingPVP || g_isBindingBridge) {
            UnregisterHotKey(hwnd, g_isBindingPVP ? 1 : 2);
            if (g_isBindingPVP) g_bindPVP = (UINT)wParam; else g_bindBridge = (UINT)wParam;
            RegisterHotKey(hwnd, g_isBindingPVP ? 1 : 2, 0, (UINT)wParam);
            g_isBindingPVP = g_isBindingBridge = false; SaveSettings();
        } return 0;
    case WM_HOTKEY:
        if (wParam == 1) { g_isClicking = !g_isClicking; g_bridgeMode = 0; }
        if (wParam == 2) { g_bridgeMode = (g_bridgeMode + 1) % 13; g_isClicking = false; }
        if (wParam == 3) {
            g_showDebug = !g_showDebug;
            int nH = g_showDebug ? WIN_HEIGHT_LARGE : WIN_HEIGHT_SMALL;
            SetWindowPos(hwnd, NULL, 0, 0, WIN_WIDTH, nH, SWP_NOMOVE | SWP_NOZORDER);
        }
        return 0;
    case WM_TIMER:
        for (auto& p : g_particles) {
            p.x += p.vx; p.y += p.vy;
            if (p.x < 0 || p.x > WIN_WIDTH) p.vx *= -1; if (p.y < 0 || p.y > WIN_HEIGHT_LARGE) p.vy *= -1;
        } InvalidateRect(hwnd, 0, 0); return 0;
    case WM_PAINT: RenderUI(hwnd); return 0;
    case WM_DESTROY: PostQuitMessage(0); return 0;
    }
    return DefWindowProc(hwnd, uMsg, wParam, lParam);
}

int WINAPI WinMain(_In_ HINSTANCE hI, _In_opt_ HINSTANCE hP, _In_ LPSTR lpC, _In_ int nS) {
    SetProcessDPIAware(); timeBeginPeriod(1);
    ULONG_PTR t; GdiplusStartupInput gs; GdiplusStartup(&t, &gs, 0);
    WNDCLASSEXW wc = { sizeof(WNDCLASSEXW), CS_HREDRAW | CS_VREDRAW, WindowProc, 0, 0, hI, 0, LoadCursor(0, IDC_ARROW), 0, 0, L"MakarClickerFix", 0 };
    RegisterClassExW(&wc);
    WNDCLASSEXW wcU = { sizeof(WNDCLASSEXW), CS_HREDRAW | CS_VREDRAW, UpdateWndProc, 0, 0, hI, 0, LoadCursor(0, IDC_ARROW), 0, 0, L"MakarUpdate", 0 };
    RegisterClassExW(&wcU);
    HWND hwnd = CreateWindowExW(WS_EX_TOPMOST | WS_EX_LAYERED, L"MakarClickerFix", L"Makar Clicker", WS_POPUP | WS_VISIBLE, 500, 100, WIN_WIDTH, WIN_HEIGHT_SMALL, 0, 0, hI, 0);
    MSG msg; while (GetMessage(&msg, 0, 0, 0)) { TranslateMessage(&msg); DispatchMessage(&msg); }
    GdiplusShutdown(t); timeEndPeriod(1); return 0;
}
