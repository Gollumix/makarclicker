std::wstring ToWString(std::string s) { return std::wstring(s.begin(), s.end()); }

static float CalculateCPULoad(unsigned __int64 idleTicks, unsigned __int64 totalTicks) {
    static unsigned __int64 _pTotal = 0, _pIdle = 0;
    unsigned __int64 totalSince = totalTicks - _pTotal;
    unsigned __int64 idleSince = idleTicks - _pIdle;
    float ret = (totalSince > 0) ? 1.0f - ((float)idleSince / totalSince) : 0.0f;
    _pTotal = totalTicks; _pIdle = idleTicks;
    return ret;
}
static unsigned __int64 FT2I64(const FILETIME& ft) { return (((unsigned __int64)ft.dwHighDateTime) << 32) | (unsigned __int64)ft.dwLowDateTime; }

void UpdateSystemUsage() {
    while (true) {
        MEMORYSTATUSEX mem; mem.dwLength = sizeof(mem);
        GlobalMemoryStatusEx(&mem); g_ramLoad = (int)mem.dwMemoryLoad;
        FILETIME idle, kern, user;
        if (GetSystemTimes(&idle, &kern, &user)) g_cpuLoad = (int)(CalculateCPULoad(FT2I64(idle), FT2I64(kern) + FT2I64(user)) * 100);
        std::this_thread::sleep_for(std::chrono::milliseconds(1000));
    }
}

