// === Dynamic colors - smoothly change hue over time ===
Color GetDynamicAccent() {
    float time = (float)GetTickCount64() / 1000.0f;  // Time in seconds since system start
    int r = (int)(127 + 127 * sin(time));              // Red waves from 0 to 254
    int g = (int)(127 + 127 * sin(time + 2.0f));       // Green phase-shifted
    int b = 255;                                        // Blue constant
    return Color(255, r, g, b);
}

