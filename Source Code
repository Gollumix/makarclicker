// === Save single profile to registry ===
void SaveProfile(int index) {
    HKEY hK;
    std::wstring path = L"Software\\MakarClicker\\Profiles\\Profile_" + std::to_wstring(index);
    if (RegCreateKeyExW(HKEY_CURRENT_USER, path.c_str(), 0, 0, REG_OPTION_NON_VOLATILE, KEY_WRITE, 0, &hK, 0) == ERROR_SUCCESS) {
        DWORD dC = (DWORD)g_cps.load();
        RegSetValueExW(hK, L"CPS", 0, REG_DWORD, (const BYTE*)&dC, 4);
        RegSetValueExW(hK, L"BindPVP", 0, REG_DWORD, (const BYTE*)&g_bindPVP, 4);
        RegSetValueExW(hK, L"BindBridge", 0, REG_DWORD, (const BYTE*)&g_bindBridge, 4);
        DWORD dA = (DWORD)g_windowAlpha;
        RegSetValueExW(hK, L"Alpha", 0, REG_DWORD, (const BYTE*)&dA, 4);
        RegSetValueExW(hK, L"UpdateUrl", 0, REG_SZ, (const BYTE*)UPDATE_JSON_URL.c_str(), (DWORD)(UPDATE_JSON_URL.length() + 1) * sizeof(wchar_t));
        RegSetValueExW(hK, L"Name", 0, REG_SZ, (const BYTE*)g_profileNames[index].c_str(), (DWORD)(g_profileNames[index].length() + 1) * sizeof(wchar_t));
        RegCloseKey(hK);
    }
}

// === Load single profile from registry ===
void LoadProfile(int index) {
    if (index < 0 || index >= MAX_PROFILES) return;
    HKEY hK;
    std::wstring path = L"Software\\MakarClicker\\Profiles\\Profile_" + std::to_wstring(index);
    if (RegOpenKeyExW(HKEY_CURRENT_USER, path.c_str(), 0, KEY_READ, &hK) == ERROR_SUCCESS) {
        DWORD dC, dP, dB, dA, dS = 4;
        if (RegQueryValueExW(hK, L"CPS", 0, 0, (LPBYTE)&dC, &dS) == ERROR_SUCCESS) g_cps = (float)dC;
        if (RegQueryValueExW(hK, L"BindPVP", 0, 0, (LPBYTE)&dP, &dS) == ERROR_SUCCESS) g_bindPVP = dP;
        if (RegQueryValueExW(hK, L"BindBridge", 0, 0, (LPBYTE)&dB, &dS) == ERROR_SUCCESS) g_bindBridge = dB;
        if (RegQueryValueExW(hK, L"Alpha", 0, 0, (LPBYTE)&dA, &dS) == ERROR_SUCCESS) {
            g_windowAlpha = (BYTE)dA;
            if (g_mainHwnd) SetLayeredWindowAttributes(g_mainHwnd, 0, g_windowAlpha, LWA_ALPHA);
        }
        wchar_t urlBuffer[512] = { 0 }; DWORD urlSize = sizeof(urlBuffer);
        if (RegQueryValueExW(hK, L"UpdateUrl", 0, 0, (LPBYTE)urlBuffer, &urlSize) == ERROR_SUCCESS) {
            UPDATE_JSON_URL = urlBuffer;
            if (IsUrlEmptyOrWhitespace(UPDATE_JSON_URL)) UPDATE_JSON_URL = DEFAULT_UPDATE_URL;
        }
        wchar_t nameBuffer[64] = { 0 }; DWORD nameSize = sizeof(nameBuffer);
        if (RegQueryValueExW(hK, L"Name", 0, 0, (LPBYTE)nameBuffer, &nameSize) == ERROR_SUCCESS) {
            g_profileNames[index] = nameBuffer;
        }
        RegCloseKey(hK);
    }
}

// === Switch to another profile (saves current, loads new) ===
void SwitchProfile(HWND hwnd, int index) {
    if (index < 0 || index >= MAX_PROFILES || index == g_currentProfile) return;
    SaveProfile(g_currentProfile);
    g_currentProfile = index;
    LoadProfile(index);
    UnregisterHotKey(hwnd, 1); UnregisterHotKey(hwnd, 2);
    RegisterHotKey(hwnd, 1, 0, g_bindPVP); RegisterHotKey(hwnd, 2, 0, g_bindBridge);
    HKEY hK;
    if (RegOpenKeyExW(HKEY_CURRENT_USER, L"Software\\MakarClicker", 0, KEY_WRITE, &hK) == ERROR_SUCCESS) {
        DWORD dIdx = (DWORD)index; RegSetValueExW(hK, L"CurrentProfile", 0, REG_DWORD, (const BYTE*)&dIdx, 4);
        RegCloseKey(hK);
    }
    SaveSettings();
}

// === Load all profile names from registry on startup ===
void InitProfiles() {
    for (int i = 0; i < MAX_PROFILES; i++) {
        HKEY hK;
        std::wstring path = L"Software\\MakarClicker\\Profiles\\Profile_" + std::to_wstring(i);
        if (RegOpenKeyExW(HKEY_CURRENT_USER, path.c_str(), 0, KEY_READ, &hK) == ERROR_SUCCESS) {
            wchar_t nameBuffer[64] = { 0 }; DWORD nameSize = sizeof(nameBuffer);
            if (RegQueryValueExW(hK, L"Name", 0, 0, (LPBYTE)nameBuffer, &nameSize) == ERROR_SUCCESS) {
                g_profileNames[i] = nameBuffer;
            }
            RegCloseKey(hK);
        }
    }
}

// === Check for updates via HTTP ===
void CheckForUpdates(HWND hwnd) {
    HINTERNET hS = WinHttpOpen(L"MakarUpdate/1.0", WINHTTP_ACCESS_TYPE_DEFAULT_PROXY, WINHTTP_NO_PROXY_NAME, WINHTTP_NO_PROXY_BYPASS, 0);
    if (!hS) return;

    // Use custom URL if set, otherwise default
    std::wstring targetUrl = IsUrlEmptyOrWhitespace(UPDATE_JSON_URL) ? DEFAULT_UPDATE_URL : UPDATE_JSON_URL;

    URL_COMPONENTS urlC = { 0 }; urlC.dwStructSize = sizeof(urlC); urlC.dwHostNameLength = (DWORD)-1; urlC.dwUrlPathLength = (DWORD)-1;
    if (WinHttpCrackUrl(targetUrl.c_str(), (DWORD)targetUrl.length(), 0, &urlC)) {
        if (urlC.lpszHostName == nullptr || urlC.dwHostNameLength == 0) { WinHttpCloseHandle(hS); return; }
        HINTERNET hC = WinHttpConnect(hS, std::wstring(urlC.lpszHostName, urlC.dwHostNameLength).c_str(), INTERNET_DEFAULT_HTTPS_PORT, 0);
        HINTERNET hR = WinHttpOpenRequest(hC, L"GET", urlC.lpszUrlPath, NULL, WINHTTP_NO_REFERER, WINHTTP_DEFAULT_ACCEPT_TYPES, WINHTTP_FLAG_SECURE);
        if (hR && WinHttpSendRequest(hR, 0, 0, 0, 0, 0, 0) && WinHttpReceiveResponse(hR, 0)) {
            std::string resp; DWORD dwAvail = 0, dwRead = 0;
            // Read response in a loop (may arrive in chunks)
            while (WinHttpQueryDataAvailable(hR, &dwAvail) && dwAvail > 0) {
                char* buf = new char[dwAvail + 1];
                if (WinHttpReadData(hR, buf, dwAvail, &dwRead)) { buf[dwRead] = 0; resp += buf; }
                delete[] buf;
            }
            // Parse JSON: search for "version" and "url"
            size_t vPos = resp.find("\"version\": \""), uPos = resp.find("\"url\": \"");
            if (vPos != std::string::npos && uPos != std::string::npos) {
                std::string v = resp.substr(vPos + 12, resp.find("\"", vPos + 12) - (vPos + 12));
                std::string u = resp.substr(uPos + 8, resp.find("\"", uPos + 8) - (uPos + 8));
                // If new version > current -> send WM_SHOW_UPDATE
                if (std::stod(v) > std::stod(std::string(CURRENT_VERSION.begin(), CURRENT_VERSION.end()))) {
                    g_newVersion = std::wstring(v.begin(), v.end()); g_downloadUrl = std::wstring(u.begin(), u.end());
                    PostMessage(hwnd, WM_SHOW_UPDATE, 0, 0);
                }
            }
        }
        if (hR) WinHttpCloseHandle(hR); if (hC) WinHttpCloseHandle(hC);
    }
    WinHttpCloseHandle(hS);
}

// === Fetch hardware and system info ===
void FetchHardwareInfo() {
    // Read CPU name from Windows registry
    HKEY hK; if (RegOpenKeyExW(HKEY_LOCAL_MACHINE, L"HARDWARE\\DESCRIPTION\\System\\CentralProcessor\\0", 0, KEY_READ, &hK) == ERROR_SUCCESS) {
        wchar_t b[256]; DWORD s = sizeof(b); if (RegQueryValueExW(hK, L"ProcessorNameString", 0, 0, (LPBYTE)b, &s) == ERROR_SUCCESS) {
            g_cpuInfo = b; g_cpuInfo.erase(0, g_cpuInfo.find_first_not_of(L" "));  // Remove leading spaces
        } RegCloseKey(hK);
    }
    // Get GPU name via EnumDisplayDevices
    DISPLAY_DEVICEW dd; dd.cb = sizeof(dd); if (EnumDisplayDevicesW(0, 0, &dd, 0)) g_gpuInfo = dd.DeviceString;
    // Get total RAM amount
    MEMORYSTATUSEX memStatus;
    memStatus.dwLength = sizeof(memStatus);
    if (GlobalMemoryStatusEx(&memStatus)) {
        int totalGB = (int)((memStatus.ullTotalPhys + (1024 * 1024 * 1024) - 1) / (1024 * 1024 * 1024));  // Round up to GB
        g_ramInfo = std::to_wstring(totalGB) + L" GB System Memory";
    }
    // Get computer name
    wchar_t cB[MAX_COMPUTERNAME_LENGTH + 1]; DWORD cS = sizeof(cB) / sizeof(cB[0]); if (GetComputerNameW(cB, &cS)) g_computerName = cB;
    // Get local IP address (IPv4)
    WSADATA wsa; if (WSAStartup(MAKEWORD(2, 2), &wsa) == 0) {
        char hn[256]; gethostname(hn, 256);
        addrinfo* res, hints = { 0 }; hints.ai_family = AF_INET;  // IPv4 only
        if (getaddrinfo(hn, 0, &hints, &res) == 0) {
            char ip[16]; inet_ntop(AF_INET, &((sockaddr_in*)res->ai_addr)->sin_addr, ip, 16);
            std::string s(ip); g_ipAddress = std::wstring(s.begin(), s.end());
            freeaddrinfo(res);
        } WSACleanup();
    }
}

// === Save settings to Windows registry ===
void SaveSettings() {
    if (IsUrlEmptyOrWhitespace(UPDATE_JSON_URL)) {
        UPDATE_JSON_URL = DEFAULT_UPDATE_URL;
    }

    HKEY hK; if (RegCreateKeyExW(HKEY_CURRENT_USER, L"Software\\MakarClicker", 0, 0, REG_OPTION_NON_VOLATILE, KEY_WRITE, 0, &hK, 0) == ERROR_SUCCESS) {
        DWORD dC = (DWORD)g_cps.load(); RegSetValueExW(hK, L"CPS", 0, REG_DWORD, (const BYTE*)&dC, 4);
        RegSetValueExW(hK, L"BindPVP", 0, REG_DWORD, (const BYTE*)&g_bindPVP, 4);
        RegSetValueExW(hK, L"BindBridge", 0, REG_DWORD, (const BYTE*)&g_bindBridge, 4);
        DWORD dAlpha = (DWORD)g_windowAlpha; RegSetValueExW(hK, L"Alpha", 0, REG_DWORD, (const BYTE*)&dAlpha, 4);
        RegSetValueExW(hK, L"UpdateUrl", 0, REG_SZ, (const BYTE*)UPDATE_JSON_URL.c_str(), (DWORD)(UPDATE_JSON_URL.length() + 1) * sizeof(wchar_t));
        DWORD dProf = (DWORD)g_currentProfile; RegSetValueExW(hK, L"CurrentProfile", 0, REG_DWORD, (const BYTE*)&dProf, 4);
        RegCloseKey(hK);
    }
    SaveProfile(g_currentProfile);
}

// === Load settings from Windows registry ===
void LoadSettings() {
    InitProfiles();
    HKEY hK; if (RegOpenKeyExW(HKEY_CURRENT_USER, L"Software\\MakarClicker", 0, KEY_READ, &hK) == ERROR_SUCCESS) {
        DWORD dProf = 0, dS = 4;
        if (RegQueryValueExW(hK, L"CurrentProfile", 0, 0, (LPBYTE)&dProf, &dS) == ERROR_SUCCESS) {
            g_currentProfile = (int)dProf;
            if (g_currentProfile < 0 || g_currentProfile >= MAX_PROFILES) g_currentProfile = 0;
        }
        RegCloseKey(hK);
    }
    LoadProfile(g_currentProfile);
}

// === Main clicker engine (runs in separate thread) ===
void ClickerEngine() {
    // Initialize random number generator
    std::random_device rd;
    std::mt19937 gen(rd());

    // Random distributions simulating human behavior
    std::normal_distribution<float> cpsNoise(0.0f, 1.8f);          // CPS noise (standard deviation 1.8)
    std::normal_distribution<float> holdTime(42.0f, 15.0f);        // Key hold time ~ skewed short (clamped 20-90)
    std::uniform_real_distribution<float> skipChance(0.0f, 1.0f);  // Chance to skip a click

    std::uniform_int_distribution<int> burstLen(2, 5);             // Clicks per burst phase
    std::uniform_real_distribution<float> burstMult(0.85f, 1.15f); // Burst CPS multiplier

    float currentDrift = 1.0f;
    int burstRemaining = 0;
    float currentBurst = 1.0f;
    auto lastDriftUpdate = std::chrono::steady_clock::now();

    // === Function performing a single click ===
    auto doClick = [&](DWORD flags) {
        float base = g_cps.load();
        auto now = std::chrono::steady_clock::now();

        // Smooth CPS drift using sine waves (continuous, no abrupt jumps)
        float t = std::chrono::duration_cast<std::chrono::milliseconds>(now - lastDriftUpdate).count() / 1000.0f;
        currentDrift = 1.0f + 0.05f * sinf(t * 0.5f) + 0.03f * sinf(t * 1.3f);

        if (burstRemaining <= 0) { burstRemaining = burstLen(gen); currentBurst = burstMult(gen); }

        float targetCPS = std::clamp(base * currentDrift * currentBurst + cpsNoise(gen), 1.0f, 50.0f);
        float holdMs = std::clamp(holdTime(gen), 20.0f, 90.0f);         // Random hold time (skewed short)
        burstRemaining--;
        // 98% chance to click (2% skip - simulate natural pauses)
        if (skipChance(gen) >= 0.02f) {
            // Press button
            INPUT down{0}; down.type = INPUT_MOUSE; down.mi.dwFlags = flags;
            SendInput(1, &down, sizeof(INPUT));
            std::this_thread::sleep_for(std::chrono::milliseconds((int)holdMs));  // Hold
            // Release button
            INPUT up{0}; up.type = INPUT_MOUSE; up.mi.dwFlags = (flags == MOUSEEVENTF_LEFTDOWN) ? MOUSEEVENTF_LEFTUP : MOUSEEVENTF_RIGHTUP;
            SendInput(1, &up, sizeof(INPUT));

            // Save click timestamp (for real CPS measurement)
            { std::lock_guard<std::mutex> lk(g_tsMutex); g_clickTimestamps.push_back(GetTickCount64()); }
        }

        // Wait remaining time to match target CPS
        int totalMs = (int)(1000.0f / targetCPS);
        int elapsedMs = (int)std::chrono::duration_cast<std::chrono::milliseconds>(std::chrono::steady_clock::now() - now).count();
        int sleepMs = totalMs - elapsedMs;
        if (sleepMs > 0) std::this_thread::sleep_for(std::chrono::milliseconds(sleepMs));
    };

    // === Main engine loop ===
    while (g_appRunning) {
        HWND fg = GetForegroundWindow();
        bool active = (fg != g_mainHwnd && fg != NULL);  // Only click when the window is not ours

        if (active) {
            if (g_isClicking.load()) doClick(MOUSEEVENTF_LEFTDOWN);   // PVP mode - left button
            else if (g_bridgeMode.load() > 0) doClick(MOUSEEVENTF_RIGHTDOWN); // Bridge mode - right button
        }
        std::this_thread::sleep_for(std::chrono::milliseconds(1));
    }
}

std::wstring GetKeyNameStr(UINT vk) {
    if (vk >= VK_F1 && vk <= VK_F12) return L"F" + std::to_wstring(vk - VK_F1 + 1);
    wchar_t n[64]; if (GetKeyNameTextW(MapVirtualKeyW(vk, MAPVK_VK_TO_VSC) << 16, n, 64)) return n;
    return L"Key " + std::to_wstring(vk);
}

void RenderUI(HWND hwnd) {
    PAINTSTRUCT ps; HDC hdc = BeginPaint(hwnd, &ps); RECT rc; GetClientRect(hwnd, &rc);
    float midX = (float)rc.right / 2.0f;
    HDC memDC = CreateCompatibleDC(hdc); HBITMAP memBm = CreateCompatibleBitmap(hdc, rc.right, rc.bottom);
    SelectObject(memDC, memBm); Graphics g(memDC);
    g.SetSmoothingMode(SmoothingModeAntiAlias); g.SetTextRenderingHint(TextRenderingHintAntiAlias);
    g.Clear(COLOR_BG);

    ULONGLONG now = GetTickCount64();
    { std::lock_guard<std::mutex> lk(g_tsMutex); g_clickTimestamps.erase(std::remove_if(g_clickTimestamps.begin(), g_clickTimestamps.end(), [now](ULONGLONG ts) { return now - ts > 1000; }), g_clickTimestamps.end()); }
    g_realCPS = (float)g_clickTimestamps.size();

    Color dynamicAccent = GetDynamicAccent();
    SolidBrush white(Color(255, 255, 255)), gray(Color(180, 150, 150, 150)), dGray(Color(100, 50, 50, 50)), barBg(Color(40, 20, 20, 20)), accent(dynamicAccent);
    FontFamily ff(L"Segoe UI");
    Font fL(&ff, 42, FontStyleBold, UnitPixel);
    Font fM(&ff, 18, FontStyleRegular, UnitPixel);
    Font fB(&ff, 20, FontStyleBold, UnitPixel);
    Font fS(&ff, 12, FontStyleRegular, UnitPixel);
    Font fSH(&ff, 14, FontStyleBold, UnitPixel);
    StringFormat sfC; sfC.SetAlignment(StringAlignmentCenter);

    g.FillRectangle(&barBg, 0.0f, 0.0f, (REAL)rc.right, (REAL)TOP_BAR_HEIGHT);
    g.DrawString(L"X", -1, &fSH, PointF((REAL)rc.right - 25.0f, 8.0f), &sfC, &white);
    g.DrawString(L"-", -1, &fSH, PointF((REAL)rc.right - 55.0f, 8.0f), &sfC, &white);

    Pen gearPen(g_showSettingsMenu ? dynamicAccent : Color(180, 150, 150, 150), 2.0f);
    g.DrawEllipse(&gearPen, 15, 10, 14, 14);
    g.DrawEllipse(&gearPen, 19, 14, 6, 6);
    for (int i = 0; i < 8; i++) {
        float angle = i * 45.0f * 3.14159f / 180.0f;
        float x1 = 22.0f + cosf(angle) * 7.0f;
        float y1 = 17.0f + sinf(angle) * 7.0f;
        float x2 = 22.0f + cosf(angle) * 10.0f;
        float y2 = 17.0f + sinf(angle) * 10.0f;
        g.DrawLine(&gearPen, x1, y1, x2, y2);
    }

    std::wstring titleText = L"MAKAR CLICKER v" + CURRENT_VERSION;
    g.DrawString(titleText.c_str(), -1, &fSH, PointF(40.0f, 8.0f), &gray);

    SolidBrush pB(Color(180, dynamicAccent.GetR(), dynamicAccent.GetG(), dynamicAccent.GetB()));
    Pen pLine(Color(100, dynamicAccent.GetR(), dynamicAccent.GetG(), dynamicAccent.GetB()), 1.0f);
    for (auto& p : g_particles) {
        g.FillEllipse(&pB, (REAL)p.x, (REAL)p.y, 3.0f, 3.0f);
        if (sqrtf(powf(p.x - (float)g_mousePos.x, 2) + powf(p.y - (float)g_mousePos.y, 2)) < 130.0f)
            g.DrawLine(&pLine, (REAL)p.x + 1.5f, (REAL)p.y + 1.5f, (REAL)g_mousePos.x, (REAL)g_mousePos.y);
    }

    g.DrawString(L"MAKAR CLICKER", -1, &fL, PointF(midX, 75.0f), &sfC, &accent);
    g.DrawString(L"SPEED CONTROL", -1, &fS, PointF(midX, 140.0f), &sfC, &gray);

    float sliderX = midX - 150.0f;
    float sliderW = 300.0f;
    float sPos = (g_cps.load() - 1.0f) / 29.0f * sliderW;

    Pen penBack(Color(40, 60, 60, 60), 8.0f);
    penBack.SetStartCap(LineCapRound); penBack.SetEndCap(LineCapRound);
    g.DrawLine(&penBack, sliderX, 185.0f, sliderX + sliderW, 185.0f);

    Pen penProgress(dynamicAccent, 8.0f);
    penProgress.SetStartCap(LineCapRound); penProgress.SetEndCap(LineCapRound);
    if (sPos > 0) g.DrawLine(&penProgress, sliderX, 185.0f, sliderX + sPos, 185.0f);

    for (int i = 1; i <= 5; i++) {
        SolidBrush glow(Color(50 / i, dynamicAccent.GetR(), dynamicAccent.GetG(), dynamicAccent.GetB()));
        g.FillEllipse(&glow, (REAL)(sliderX + sPos - 12.0f - i), 173.0f - i, 24.0f + (i * 2), 24.0f + (i * 2));
    }

    SolidBrush handleInner(Color(255, 255, 255));
    Pen handleBorder(dynamicAccent, 2.0f);
    g.FillEllipse(&handleInner, (REAL)(sliderX + sPos - 10.0f), 175.0f, 20.0f, 20.0f);
    g.DrawEllipse(&handleBorder, (REAL)(sliderX + sPos - 10.0f), 175.0f, 20.0f, 20.0f);

    std::wstring cpsText = std::to_wstring((int)g_cps.load()) + L" CPS";
    g.DrawString(cpsText.c_str(), -1, &fB, PointF(midX, 155.0f), &sfC, &white);

    std::wstring realCpsDisplay = L"REAL SPEED: " + std::to_wstring((int)g_realCPS) + L" CPS";
    g.DrawString(realCpsDisplay.c_str(), -1, &fS, PointF(midX, 230.0f), &sfC, &accent);

    g.DrawString(L"PVP BIND", -1, &fM, PointF(midX - 70.0f, 265.0f), &sfC, &gray);
    g.DrawString(GetKeyNameStr(g_bindPVP).c_str(), -1, &fB, PointF(midX + 70.0f, 265.0f), &sfC, g_isBindingPVP ? &accent : &white);
    g.DrawString(L"BRIDGE BIND", -1, &fM, PointF(midX - 70.0f, 315.0f), &sfC, &gray);
    g.DrawString(GetKeyNameStr(g_bindBridge).c_str(), -1, &fB, PointF(midX + 70.0f, 315.0f), &sfC, g_isBindingBridge ? &accent : &white);

    std::wstring modeText = L"MODE: " + g_modeNames[g_bridgeMode.load()];
    g.DrawString(modeText.c_str(), -1, &fB, PointF(midX, 365.0f), &sfC, &accent);

    std::wstring profileText = L"PROFILE:  <  " + g_profileNames[g_currentProfile] + L"  >";
    g.DrawString(profileText.c_str(), -1, &fM, PointF(midX, 395.0f), &sfC, g_isEditingProfile ? (Brush*)&accent : (Brush*)&gray);

    RectF stRect(midX - 180.0f, 440.0f, 360.0f, 60.0f);
    SolidBrush stBg(Color(35, 255, 255, 255));
    Pen stBorder(g_isClicking.load() ? Color(255, 0, 255, 0) : dynamicAccent, 2.0f);
    g.FillRectangle(&stBg, stRect);
    g.DrawRectangle(&stBorder, stRect);
    g.DrawString(g_isClicking.load() ? L"ENGINE ACTIVE" : L"ENGINE STANDBY", -1, &fB, PointF(midX, 453.0f), &sfC, &white);

    if (g_showDebug) {
        Pen sep(Color(100, 255, 255, 255), 1.0f);
        g.DrawLine(&sep, 50.0f, 535.0f, (REAL)rc.right - 50.0f, 535.0f);
        g.DrawString(L"DEBUG / SYSTEM MONITOR", -1, &fS, PointF(midX, 545.0f), &sfC, &accent);
        g.DrawString((L"CPU: " + g_cpuInfo).c_str(), -1, &fS, PointF(midX, 565.0f), &sfC, &white);
        g.DrawString((L"GPU: " + g_gpuInfo).c_str(), -1, &fS, PointF(midX, 582.0f), &sfC, &white);
        g.DrawString((L"RAM: " + g_ramInfo).c_str(), -1, &fS, PointF(midX, 599.0f), &sfC, &white);
        std::wstring loadTxt = L"LOAD -> CPU: " + std::to_wstring(g_cpuLoad) + L"% | RAM: " + std::to_wstring(g_ramLoad) + L"%";
        g.DrawString(loadTxt.c_str(), -1, &fS, PointF(midX, 620.0f), &sfC, &accent);
        std::wstring footer = L"PC: " + g_computerName + L" | IP: " + g_ipAddress;
        g.DrawString(footer.c_str(), -1, &fS, PointF(midX, 640.0f), &sfC, &gray);
        std::wstring buildTxt = L"BUILD: " + BUILD_ID + L" | DATE: " + ToWString(B_DATE) + L" " + ToWString(B_TIME);
        g.DrawString(buildTxt.c_str(), -1, &fS, PointF(midX, 665.0f), &sfC, &accent);

        RectF sdRect(midX - 75.0f, 690.0f, 150.0f, 30.0f);
        SolidBrush sdBg(Color(180, 200, 0, 0));
        g.FillRectangle(&sdBg, sdRect);
        Pen whitePen(Color(255, 255, 255), 1.0f);
        g.DrawRectangle(&whitePen, sdRect);
        g.DrawString(L"SELF DESTRUCT", -1, &fS, PointF(midX, 698.0f), &sfC, &white);
    }

    if (g_showSettingsMenu) {
        SolidBrush menuBg(Color(245, 15, 15, 15));
        Pen menuBorder(dynamicAccent, 1.5f);
        g.FillRectangle(&menuBg, g_menuRect);
        g.DrawRectangle(&menuBorder, g_menuRect);

        std::wstring options[] = { L"Opacity: 100%", L"Opacity: 90%", L"Opacity: 75%", L"Opacity: 60%", L"Opacity: 50%" };
        BYTE alphas[] = { 255, 230, 191, 153, 128 };

        for (int i = 0; i < 5; i++) {
            float itemY = g_menuRect.Y + 10.0f + (i * 28.0f);
            bool isSelected = (g_windowAlpha == alphas[i]);

            if (g_mousePos.x >= g_menuRect.X && g_mousePos.x <= g_menuRect.X + g_menuRect.Width &&
                g_mousePos.y >= itemY && g_mousePos.y < itemY + 25.0f) {
                SolidBrush hoverBrush(Color(40, dynamicAccent.GetR(), dynamicAccent.GetG(), dynamicAccent.GetB()));
                g.FillRectangle(&hoverBrush, g_menuRect.X + 5.0f, itemY, g_menuRect.Width - 10.0f, 24.0f);
            }

            std::wstring renderText = isSelected ? L"[\u2713] " + options[i] : options[i];
            SolidBrush* textBrush = isSelected ? new SolidBrush(dynamicAccent) : &white;
            g.DrawString(renderText.c_str(), -1, &fS, PointF(g_menuRect.X + 15.0f, itemY + 3.0f), textBrush);
            if (isSelected) delete textBrush;
        }

        SolidBrush* titleBrush = g_isEditingUrl ? new SolidBrush(dynamicAccent) : &white;
        g.DrawString(L"Custom Update Server", -1, &fS, PointF(g_menuRect.X + 12.0f, g_menuRect.Y + 153.0f), titleBrush);
        if (g_isEditingUrl) delete titleBrush;

        RectF inputRect(g_menuRect.X + 10.0f, g_menuRect.Y + 170.0f, g_menuRect.Width - 20.0f, 25.0f);
        SolidBrush inputBg(Color(40, 255, 255, 255));
        g.FillRectangle(&inputBg, inputRect);

        Pen fieldPen(g_isEditingUrl ? dynamicAccent : Color(150, 100, 100, 100), 1.5f);
        g.DrawRectangle(&fieldPen, inputRect);

        std::wstring dispUrl = UPDATE_JSON_URL;
        if (dispUrl.length() > 34 && !g_isEditingUrl) {
            dispUrl = dispUrl.substr(0, 31) + L"...";
        }
        else if (dispUrl.length() > 34 && g_isEditingUrl) {
            dispUrl = L"..." + dispUrl.substr(dispUrl.length() - 31);
        }

        if (!dispUrl.empty()) {
            g.DrawString(dispUrl.c_str(), -1, &fS, PointF(inputRect.X + 5.0f, inputRect.Y + 5.0f), &white);
        }
    }

    float finalBottom = g_showDebug ? 730.0f : 525.0f;
    if (!g_showDebug) g.DrawString(L"", -1, &fS, PointF(midX, finalBottom - 20.0f), &sfC, &dGray);
    std::wstring copyTxt = L"COPYRIGHT 2026 " + g_licenseUser;
    g.DrawString(copyTxt.c_str(), -1, &fS, PointF(midX, finalBottom), &sfC, &gray);

    BitBlt(hdc, 0, 0, rc.right, rc.bottom, memDC, 0, 0, SRCCOPY);
    DeleteObject(memBm); DeleteDC(memDC); EndPaint(hwnd, &ps);
}

LRESULT CALLBACK WindowProc(HWND hwnd, UINT uMsg, WPARAM wParam, LPARAM lParam) {
    switch (uMsg) {
    case WM_CREATE:
        LoadSettings(); FetchHardwareInfo(); g_mainHwnd = hwnd;
        SetLayeredWindowAttributes(hwnd, 0, g_windowAlpha, LWA_ALPHA);
        {
            DWORD cornerPreference = 2;
            DwmSetWindowAttribute(hwnd, 33, &cornerPreference, sizeof(cornerPreference));
        }
        for (int i = 0; i < 80; i++) g_particles.push_back({ (float)(rand() % WIN_WIDTH), (float)(rand() % WIN_HEIGHT_LARGE), (float)((rand() % 10 - 5) / 6.0f), (float)((rand() % 10 - 5) / 6.0f) });
        RegisterHotKey(hwnd, 1, 0, g_bindPVP);
        RegisterHotKey(hwnd, 2, 0, g_bindBridge);
        RegisterHotKey(hwnd, 3, MOD_CONTROL, VK_F10);
        std::thread(ClickerEngine).detach();
        std::thread(UpdateSystemUsage).detach();
        std::thread(CheckForUpdates, hwnd).detach();
        SetTimer(hwnd, 1, 16, 0); return 0;

    case WM_SHOW_UPDATE: {
        HWND hU = CreateWindowExW(WS_EX_TOPMOST | WS_EX_LAYERED, L"MakarUpdate", L"Update", WS_POPUP | WS_VISIBLE, 575, 375, 400, 260, hwnd, 0, GetModuleHandle(0), 0);
        {
            DWORD cornerPreference = 2;
            DwmSetWindowAttribute(hU, 33, &cornerPreference, sizeof(cornerPreference));
        }
        SetLayeredWindowAttributes(hU, 0, 250, LWA_ALPHA); return 0;
    }
    case WM_LBUTTONDOWN: {
        int x = LOWORD(lParam), y = HIWORD(lParam);

        if (g_showSettingsMenu && x >= g_menuRect.X && x <= g_menuRect.X + g_menuRect.Width) {
            for (int i = 0; i < 5; i++) {
                float itemY = g_menuRect.Y + 10.0f + (i * 28.0f);
                if (y >= itemY && y < itemY + 25.0f) {
                    switch (i) {
                    case 0: g_windowAlpha = 255; break;
                    case 1: g_windowAlpha = 230; break;
                    case 2: g_windowAlpha = 191; break;
                    case 3: g_windowAlpha = 153; break;
                    case 4: g_windowAlpha = 128; break;
                    }
                    SetLayeredWindowAttributes(hwnd, 0, g_windowAlpha, LWA_ALPHA);

                    if (g_isEditingUrl) {
                        g_isEditingUrl = false;
                        if (IsUrlEmptyOrWhitespace(UPDATE_JSON_URL)) UPDATE_JSON_URL = DEFAULT_UPDATE_URL;
                    }
                    SaveSettings();
                    g_showSettingsMenu = false;
                    return 0;
                }
            }

            float inputY = g_menuRect.Y + 170.0f;
            if (x >= g_menuRect.X + 10.0f && x <= g_menuRect.X + g_menuRect.Width - 10.0f &&
                y >= inputY && y <= inputY + 25.0f) {
                g_isEditingUrl = true;
                return 0;
            }
        }

        if (g_isEditingUrl) {
            g_isEditingUrl = false;
            if (IsUrlEmptyOrWhitespace(UPDATE_JSON_URL)) UPDATE_JSON_URL = DEFAULT_UPDATE_URL;
            SaveSettings();
        }

        if (y <= TOP_BAR_HEIGHT) {
            if (x >= 10 && x <= 40) {
                g_showSettingsMenu = !g_showSettingsMenu;
                return 0;
            }
            if (x >= (int)WIN_WIDTH - 40) DestroyWindow(hwnd);
            else if (x >= (int)WIN_WIDTH - 70) ShowWindow(hwnd, SW_MINIMIZE);
            else { ReleaseCapture(); SendMessage(hwnd, WM_NCLBUTTONDOWN, HTCAPTION, 0); }
        }
        else if (y > 160 && y < 210) { g_isDraggingSlider = true; SetCapture(hwnd); g_showSettingsMenu = false; }
        else if (y > 250 && y < 300 && x > WIN_WIDTH / 2) { g_isBindingPVP = true; g_showSettingsMenu = false; }
        else if (y > 300 && y < 350 && x > WIN_WIDTH / 2) { g_isBindingBridge = true; g_showSettingsMenu = false; }
        else if (y > 380 && y < 420) {
            if (x > WIN_WIDTH / 2 - 130 && x < WIN_WIDTH / 2 - 80) SwitchProfile(hwnd, (g_currentProfile - 1 + MAX_PROFILES) % MAX_PROFILES);
            else if (x > WIN_WIDTH / 2 + 80 && x < WIN_WIDTH / 2 + 130) SwitchProfile(hwnd, (g_currentProfile + 1) % MAX_PROFILES);
            else g_showSettingsMenu = false;
        }
        else {
            g_showSettingsMenu = false;
        }

        if (g_showDebug && x > WIN_WIDTH / 2 - 75 && x < WIN_WIDTH / 2 + 75 && y > 690 && y < 720) {
            DestroyWindow(hwnd);
        }
        return 0;
    }
    case WM_LBUTTONUP: g_isDraggingSlider = false; ReleaseCapture(); SaveSettings(); return 0;
    case WM_MOUSEMOVE:
        g_mousePos = { LOWORD(lParam), HIWORD(lParam) };
        if (g_isDraggingSlider) {
            float start = WIN_WIDTH / 2.0f - 150.0f;
            g_cps = std::clamp(1.0f + (((float)LOWORD(lParam) - start) / 300.0f) * 29.0f, 1.0f, 30.0f);
        } return 0;
    case WM_KEYDOWN:
        if (g_isEditingUrl) {
            if (wParam == 'V' && (GetKeyState(VK_CONTROL) & 0x8000)) {
                if (OpenClipboard(hwnd)) {
                    HANDLE hData = GetClipboardData(CF_UNICODETEXT);
                    if (hData) {
                        wchar_t* pText = static_cast<wchar_t*>(GlobalLock(hData));
                        if (pText) UPDATE_JSON_URL += pText;
                        GlobalUnlock(hData);
                    }
                    CloseClipboard();
                }
                return 0;
            }
            if (wParam == VK_RETURN) {
                g_isEditingUrl = false;
                if (IsUrlEmptyOrWhitespace(UPDATE_JSON_URL)) UPDATE_JSON_URL = DEFAULT_UPDATE_URL;
                SaveSettings();
                return 0;
            }
        }

        if (g_isBindingPVP || g_isBindingBridge) {
            UnregisterHotKey(hwnd, g_isBindingPVP ? 1 : 2);
            if (g_isBindingPVP) g_bindPVP = (UINT)wParam; else g_bindBridge = (UINT)wParam;
            RegisterHotKey(hwnd, g_isBindingPVP ? 1 : 2, 0, (UINT)wParam);
            g_isBindingPVP = g_isBindingBridge = false; SaveSettings();
        } return 0;

    case WM_CHAR:
        if (g_isEditingUrl) {
            wchar_t ch = (wchar_t)wParam;
            if (ch == VK_BACK) {
                if (!UPDATE_JSON_URL.empty()) UPDATE_JSON_URL.pop_back();
            }
            else if (ch >= 32 && ch != VK_RETURN) {
                UPDATE_JSON_URL += ch;
            }
            return 0;
        }
        break;

    case WM_HOTKEY:
        if (wParam == 1) { g_isClicking = !g_isClicking.load(); g_bridgeMode = 0; }
        if (wParam == 2) { g_bridgeMode = (g_bridgeMode.load() + 1) % 13; g_isClicking = false; }
        if (wParam == 3) {
            g_showDebug = !g_showDebug;
            int nH = g_showDebug ? WIN_HEIGHT_LARGE : WIN_HEIGHT_SMALL;
            SetWindowPos(hwnd, NULL, 0, 0, WIN_WIDTH, nH, SWP_NOMOVE | SWP_NOZORDER);
        }
        return 0;
    case WM_TIMER:
        for (auto& p : g_particles) {
            p.x += p.vx; p.y += p.vy;
            if (p.x < 0 || p.x > WIN_WIDTH) p.vx *= -1; if (p.y < 0 || p.y > WIN_HEIGHT_LARGE) p.vy *= -1;
        } InvalidateRect(hwnd, 0, 0); return 0;
    case WM_PAINT: RenderUI(hwnd); return 0;
    case WM_DESTROY: g_appRunning = false; SaveSettings(); PostQuitMessage(0); return 0;
    }
    return DefWindowProc(hwnd, uMsg, wParam, lParam);
}

int WINAPI WinMain(_In_ HINSTANCE hI, _In_opt_ HINSTANCE hP, _In_ LPSTR lpC, _In_ int nS) {
    SetProcessDPIAware(); timeBeginPeriod(1);
    ULONG_PTR t; GdiplusStartupInput gs; GdiplusStartup(&t, &gs, 0);

    WNDCLASSEXW wc = { sizeof(WNDCLASSEXW), CS_HREDRAW | CS_VREDRAW, WindowProc, 0, 0, hI, 0, LoadCursor(0, IDC_ARROW), 0, 0, L"MakarClickerFix", 0 };
    RegisterClassExW(&wc);
    WNDCLASSEXW wcU = { sizeof(WNDCLASSEXW), CS_HREDRAW | CS_VREDRAW, UpdateWndProc, 0, 0, hI, 0, LoadCursor(0, IDC_ARROW), 0, 0, L"MakarUpdate", 0 };
    RegisterClassExW(&wcU);
    HWND hwnd = CreateWindowExW(WS_EX_TOPMOST | WS_EX_LAYERED, L"MakarClickerFix", L"Makar Clicker", WS_POPUP | WS_VISIBLE, 500, 100, WIN_WIDTH, WIN_HEIGHT_SMALL, 0, 0, hI, 0);
    MSG msg; while (GetMessage(&msg, 0, 0, 0)) { TranslateMessage(&msg); DispatchMessage(&msg); }
    GdiplusShutdown(t); timeEndPeriod(1); return 0;
}
