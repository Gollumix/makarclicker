// === Calculate CPU load from idle/total times ===
static float CalculateCPULoad(unsigned __int64 idleTicks, unsigned __int64 totalTicks) {
    static unsigned __int64 _pTotal = 0, _pIdle = 0;  // Previous values
    unsigned __int64 totalSince = totalTicks - _pTotal; // Difference since last measurement
    unsigned __int64 idleSince = idleTicks - _pIdle;
    float ret = (totalSince > 0) ? 1.0f - ((float)idleSince / totalSince) : 0.0f;
    _pTotal = totalTicks; _pIdle = idleTicks;  // Save for next time
    return ret;
}
// === FILETIME to 64-bit integer conversion ===
static unsigned __int64 FT2I64(const FILETIME& ft) { return (((unsigned __int64)ft.dwHighDateTime) << 32) | (unsigned __int64)ft.dwLowDateTime; }

// === Thread - update CPU/RAM load every second ===
void UpdateSystemUsage() {
    while (g_appRunning) {
        MEMORYSTATUSEX mem; mem.dwLength = sizeof(mem);
        GlobalMemoryStatusEx(&mem); g_ramLoad = (int)mem.dwMemoryLoad;  // RAM usage %
        FILETIME idle, kern, user;
        if (GetSystemTimes(&idle, &kern, &user)) g_cpuLoad = (int)(CalculateCPULoad(FT2I64(idle), FT2I64(kern) + FT2I64(user)) * 100);
        std::this_thread::sleep_for(std::chrono::milliseconds(1000));  // Wait 1s
    }
}

// === Render update window (GDI+) ===
void RenderUpdateUI(HWND hwnd) {
    PAINTSTRUCT ps; HDC hdc = BeginPaint(hwnd, &ps);
    RECT rc; GetClientRect(hwnd, &rc);
    // Double buffering - draw in memory first, then copy to screen
    HDC memDC = CreateCompatibleDC(hdc); HBITMAP memBm = CreateCompatibleBitmap(hdc, rc.right, rc.bottom);
    SelectObject(memDC, memBm); Graphics g(memDC);
    g.SetSmoothingMode(SmoothingModeAntiAlias); g.SetTextRenderingHint(TextRenderingHintAntiAlias);
    g.Clear(COLOR_BG);

    FontFamily ff(L"Segoe UI");
    Font fBig(&ff, 26, FontStyleBold, UnitPixel);
    Font fSmall(&ff, 15, FontStyleRegular, UnitPixel);
    SolidBrush white(Color(255, 255, 255)), accent(GetDynamicAccent()), btnB(Color(150, 0, 122, 255));
    Pen btnP(GetDynamicAccent(), 2.0f);
    StringFormat sf; sf.SetAlignment(StringAlignmentCenter);

    // Text "NEW UPDATE AVAILABLE"
    g.DrawString(L"NEW UPDATE AVAILABLE!", -1, &fBig, PointF((REAL)rc.right / 2.0f, 40.0f), &sf, &accent);
    std::wstring info = L"Version " + g_newVersion + L" is ready.";
    g.DrawString(info.c_str(), -1, &fSmall, PointF((REAL)rc.right / 2.0f, 90.0f), &sf, &white);

    // Button "DOWNLOAD NOW"
    RectF btnRect((REAL)rc.right / 2.0f - 100.0f, 150.0f, 200.0f, 45.0f);
    g.FillRectangle(&btnB, btnRect);
    g.DrawRectangle(&btnP, btnRect);
    g.DrawString(L"DOWNLOAD NOW", -1, &fSmall, PointF((REAL)rc.right / 2.0f, 162.0f), &sf, &white);

    // Copy from memory to screen
    BitBlt(hdc, 0, 0, rc.right, rc.bottom, memDC, 0, 0, SRCCOPY);
    DeleteObject(memBm); DeleteDC(memDC); EndPaint(hwnd, &ps);
}

// === Update window procedure (message handling) ===
LRESULT CALLBACK UpdateWndProc(HWND hwnd, UINT uMsg, WPARAM wParam, LPARAM lParam) {
    if (uMsg == WM_PAINT) RenderUpdateUI(hwnd);
    if (uMsg == WM_LBUTTONDOWN) {
        int x = LOWORD(lParam), y = HIWORD(lParam);
        // Click "DOWNLOAD NOW" button -> open URL in browser
        if (x > 100 && x < 300 && y > 150 && y < 195) { ShellExecuteW(0, L"open", g_downloadUrl.c_str(), 0, 0, SW_SHOWNORMAL); DestroyWindow(hwnd); }
    }
    if (uMsg == WM_KEYDOWN && wParam == VK_ESCAPE) DestroyWindow(hwnd);  // ESC closes window
    return DefWindowProc(hwnd, uMsg, wParam, lParam);
}

// === Check if URL is empty or contains only whitespace ===
bool IsUrlEmptyOrWhitespace(const std::wstring& str) {
    if (str.empty()) return true;
    return std::all_of(str.begin(), str.end(), [](wchar_t ch) { return iswspace(ch); });
}

